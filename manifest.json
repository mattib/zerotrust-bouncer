{
  "manifest_version": 3,
  "name": "Spiimask",
  "version": "0.5.1",
  "author": "Matti B. <mattiba@gmail.com>",
  "description": "AI Privacy Masking Extension",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://claude.ai/*"
      ],
      "js": [
        "brand.js",
        "content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://claude.ai/*"
      ],
      "js": [
        "brand.js",
        "core.js",
        "providers/chatgpt.js",
        "providers/gemini.js",
        "providers/claude.js",
        "inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "128": "assets/icon-128.png"
  }
}
