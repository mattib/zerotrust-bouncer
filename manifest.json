{
  "manifest_version": 3,
  "name": "ZeroTrust Bouncer POC",
  "version": "0.1.3",
  "description": "POC for AI Privacy Masking on ChatGPT",
  "content_scripts": [
    {
      "matches": ["*://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inject.js"],
      "matches": ["*://chatgpt.com/*"]
    }
  ]
}
