{
  "manifest_version": 3,
  "name": "ZeroTrust Bouncer POC",
  "version": "0.2.9",
  "description": "POC for AI Privacy Masking on ChatGPT",
  "content_scripts": [
    {
      "matches": ["*://chatgpt.com/*", "*://gemini.google.com/*", "*://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://chatgpt.com/*", "*://gemini.google.com/*", "*://claude.ai/*"],
      "js": [
        "core.js", 
        "providers/chatgpt.js", 
        "providers/gemini.js", 
        "providers/claude.js", 
        "inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
