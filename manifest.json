{
  "manifest_version": 3,
  "name": "ZeroTrust Bouncer",
  "version": "0.4.22",
  "author": "Matti B. <mattiba@gmail.com>",
  "description": "AI Privacy Masking Extension",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["*://chatgpt.com/*", "*://gemini.google.com/*", "*://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://chatgpt.com/*", "*://gemini.google.com/*", "*://claude.ai/*"],
      "js": [
        "core.js", 
        "providers/chatgpt.js", 
        "providers/gemini.js", 
        "providers/claude.js", 
        "inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
